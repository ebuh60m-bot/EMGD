{
  "entities": {
    "EmergencyEntry": {
      "title": "Emergency Training Entry",
      "description": "A user's submission for emergency procedures on a specific date, grouped by questions.",
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "description": "The date of the training in YYYY-MM-DD format."
        },
        "answers": {
          "type": "object",
          "properties": {
            "q1": { "type": "string" },
            "q2": { "type": "string" },
            "q3": { "type": "string" },
            "q4": { "type": "string" }
          },
          "description": "Answers for each of the 4 emergency questions."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Server timestamp of creation."
        }
      },
      "required": ["date", "answers", "createdAt"]
    },
    "LimitationEntry": {
      "title": "Limitations Training Entry",
      "description": "A summary of a user's attempt at the limitations test.",
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "description": "The date of the training in YYYY-MM-DD format."
        },
        "filled": {
          "type": "integer",
          "description": "Number of fields filled by the user."
        },
        "correct": {
          "type": "integer",
          "description": "Number of correct answers."
        },
        "wrong": {
          "type": "integer",
          "description": "Number of wrong answers."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Server timestamp of creation."
        }
      },
      "required": ["date", "filled", "correct", "wrong", "createdAt"]
    },
    "ConfigEntry": {
      "title": "Application Configuration",
      "description": "System-wide settings.",
      "type": "object",
      "properties": {
        "value": { "type": "string" }
      },
      "required": ["value"]
    },
    "ExamEntry": {
      "title": "Exam Submission Entry",
      "description": "An exam submission containing student info, limitation answers, emergency answers, and optional corrector evaluations.",
      "type": "object",
      "properties": {
        "studentName": { "type": "string" },
        "role": { "type": "string" },
        "limitationsAnswers": { "type": "object" },
        "emergenciesAnswers": { "type": "object" },
        "status": { "type": "string" },
        "correctorName": { "type": "string" },
        "emergenciesCorrection": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "correctedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentName", "role", "limitationsAnswers", "emergenciesAnswers", "status", "createdAt"]
    }
  },
  "firestore": {
    "/emergencies/{id}": {
      "schema": "EmergencyEntry",
      "description": "Collection of anonymous emergency procedure submissions."
    },
    "/limitations/{id}": {
      "schema": "LimitationEntry",
      "description": "Collection of anonymous limitations test results."
    },
    "/config/{id}": {
      "schema": "ConfigEntry",
      "description": "General application configuration."
    },
    "/exams/{id}": {
      "schema": "ExamEntry",
      "description": "Collection of exam submissions by pilots and mechanics."
    }
  }
}
